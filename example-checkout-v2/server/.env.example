# PAY.JP API キー
# テスト環境: sk_test_xxxxx
# 本番環境: sk_live_xxxxx
PAYJP_SECRET_KEY=sk_test_xxxxx

# Webhook シークレット（任意）
# PAY.JP ダッシュボードで設定したトークン
PAYJP_WEBHOOK_SECRET=whook_xxxxx

# サーバーポート
PORT=3000

# サンプル商品（単一）
PAYJP_SAMPLE_PRICE_ID=price_xxx
PAYJP_SAMPLE_PRODUCT_NAME=テスト商品
# 省略時は100円
PAYJP_SAMPLE_PRODUCT_AMOUNT=100
